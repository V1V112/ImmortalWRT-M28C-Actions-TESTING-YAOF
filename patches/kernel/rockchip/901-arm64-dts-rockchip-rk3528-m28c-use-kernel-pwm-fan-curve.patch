From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ImmortalWrt M28C Builder <builder@example.invalid>
Date: Wed, 29 Apr 2026 00:00:00 +0800
Subject: [PATCH] arm64: dts: rockchip: rk3528-m28c: use stepped safe PWM fan curve

The MangoPi M28C DTS already exposes the PWM fan as a thermal cooling
device. Keep fan speed policy in the kernel thermal framework by using a
project-owned fine-grained fan curve. RK3528A M28C boards can become
unstable near 75C, so start airflow early, ramp smoothly through the 50-60C
range, and reach full speed before 70C without needing a userspace Fan
Control daemon.

Signed-off-by: ImmortalWrt M28C Builder <builder@example.invalid>
---
 target/linux/rockchip/files/arch/arm64/boot/dts/rockchip/rk3528-mangopi-m28c.dts | 94 +++++++++++++++++++++++++++++++++++++++++++++-------------
 1 file changed, 69 insertions(+), 25 deletions(-)

--- a/target/linux/rockchip/files/arch/arm64/boot/dts/rockchip/rk3528-mangopi-m28c.dts
+++ b/target/linux/rockchip/files/arch/arm64/boot/dts/rockchip/rk3528-mangopi-m28c.dts
@@ -28,5 +28,5 @@
 	fan: pwm-fan {
 		compatible = "pwm-fan";
-		cooling-levels = <0 100 150 200 255>;
+		cooling-levels = <0 90 120 150 180 205 230 245 255>;
 		#cooling-cells = <2>;
 		pwms = <&pwm3 0 1000000 0>;
@@ -47,49 +47,93 @@
 &soc_thermal {
 	trips {
-		cpu_passive: trip-cpu-passive {
-			temperature = <45000>;
-			hysteresis = <2000>;
+		cpu_fan_start: trip-cpu-fan-start {
+			temperature = <38000>;
+			hysteresis = <3000>;
 			type = "active";
 		};
 
-		cpu_active: trip-cpu-active {
-			temperature = <55000>;
-			hysteresis = <2000>;
+		cpu_fan_low: trip-cpu-fan-low {
+			temperature = <45000>;
+			hysteresis = <3000>;
 			type = "active";
 		};
 
-		cpu_warm: trip-cpu-warm {
-			temperature = <65000>;
-			hysteresis = <2000>;
+		cpu_fan_mid_low: trip-cpu-fan-mid-low {
+			temperature = <50000>;
+			hysteresis = <3000>;
 			type = "active";
 		};
 
-		cpu_hot: trip-cpu-hot {
-			temperature = <75000>;
-			hysteresis = <2000>;
+		cpu_fan_mid: trip-cpu-fan-mid {
+			temperature = <55000>;
+			hysteresis = <3000>;
+			type = "active";
+		};
+
+		cpu_fan_mid_high: trip-cpu-fan-mid-high {
+			temperature = <60000>;
+			hysteresis = <3000>;
+			type = "active";
+		};
+
+		cpu_fan_high: trip-cpu-fan-high {
+			temperature = <63000>;
+			hysteresis = <3000>;
+			type = "active";
+		};
+
+		cpu_fan_boost: trip-cpu-fan-boost {
+			temperature = <66000>;
+			hysteresis = <3000>;
+			type = "active";
+		};
+
+		cpu_fan_full: trip-cpu-fan-full {
+			temperature = <68000>;
+			hysteresis = <3000>;
 			type = "active";
 		};
 	};
 
 	cooling-maps {
-		map-cpu-passive {
-			trip = <&cpu_passive>;
+		map-cpu-fan-start {
+			trip = <&cpu_fan_start>;
-			cooling-device = <&fan THERMAL_NO_LIMIT 1>;
+			cooling-device = <&fan 1 1>;
 		};
 
-		map-cpu-active {
-			trip = <&cpu_active>;
+		map-cpu-fan-low {
+			trip = <&cpu_fan_low>;
-			cooling-device = <&fan 1 2>;
+			cooling-device = <&fan 2 2>;
 		};
 
-		map-cpu-warm {
-			trip = <&cpu_warm>;
+		map-cpu-fan-mid-low {
+			trip = <&cpu_fan_mid_low>;
-			cooling-device = <&fan 2 3>;
+			cooling-device = <&fan 3 3>;
 		};
 
-		map-cpu-hot {
-			trip = <&cpu_hot>;
-			cooling-device = <&fan 3 THERMAL_NO_LIMIT>;
+		map-cpu-fan-mid {
+			trip = <&cpu_fan_mid>;
+			cooling-device = <&fan 4 4>;
+		};
+
+		map-cpu-fan-mid-high {
+			trip = <&cpu_fan_mid_high>;
+			cooling-device = <&fan 5 5>;
+		};
+
+		map-cpu-fan-high {
+			trip = <&cpu_fan_high>;
+			cooling-device = <&fan 6 6>;
+		};
+
+		map-cpu-fan-boost {
+			trip = <&cpu_fan_boost>;
+			cooling-device = <&fan 7 7>;
+		};
+
+		map-cpu-fan-full {
+			trip = <&cpu_fan_full>;
+			cooling-device = <&fan 8 8>;
 		};
 	};
 };
