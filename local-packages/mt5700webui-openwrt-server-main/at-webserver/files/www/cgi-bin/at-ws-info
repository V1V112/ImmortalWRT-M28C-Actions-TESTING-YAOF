#!/bin/sh

echo "Content-Type: application/json"
echo "Access-Control-Allow-Origin: *"
echo ""

WS_PORT=$(uci get at-webserver.config.websocket_port 2>/dev/null || echo "8765")
ALLOW_WAN=$(uci get at-webserver.config.websocket_allow_wan 2>/dev/null || echo "0")
AUTH_KEY=$(uci get at-webserver.config.websocket_auth_key 2>/dev/null || echo "")

if [ -n "$AUTH_KEY" ]; then
	REQUIRE_AUTH="true"
else
	REQUIRE_AUTH="false"
fi

if [ -n "$HTTP_HOST" ]; then
	case "$HTTP_HOST" in
		\[*\]:*)
			WS_HOST="${HTTP_HOST#\[}"
			WS_HOST="${WS_HOST%%\]:*}"
			;;
		\[*\])
			WS_HOST="${HTTP_HOST#\[}"
			WS_HOST="${WS_HOST%\]}"
			;;
		*:*:*)
			WS_HOST="$HTTP_HOST"
			;;
		*:*)
			WS_HOST="${HTTP_HOST%%:*}"
			;;
		*)
			WS_HOST="$HTTP_HOST"
			;;
	esac
fi

[ -z "$WS_HOST" ] && WS_HOST="$(uci get network.lan.ipaddr 2>/dev/null)"
[ -z "$WS_HOST" ] && WS_HOST="$(uci get network.lan.ip6addr 2>/dev/null | cut -d'/' -f1)"
[ -z "$WS_HOST" ] && WS_HOST="192.168.1.1"

case "$WS_HOST" in
	*:*:*)
		WS_URL="ws://[${WS_HOST}]:${WS_PORT}"
		;;
	*)
		WS_URL="ws://${WS_HOST}:${WS_PORT}"
		;;
esac

cat <<EOF
{
  "success": true,
  "data": {
    "host": "${WS_HOST}",
    "port": ${WS_PORT},
    "allow_wan": ${ALLOW_WAN},
    "require_auth": ${REQUIRE_AUTH},
    "ws_url": "${WS_URL}",
    "timestamp": $(date +%s)
  }
}
EOF
